#include <DHT.h>
#include <Servo.h>
#include <Wire.h>
#include <MPU6050.h>


#define PIN_DHT        5
#define PIN_MQ2        A0
#define PIN_MPU_INT    7   
#define PIN_MOVIMIENTO 8
#define PIN_SERVO      9
#define PIN_LED_VERDE  10
#define PIN_LED_AMBAR  11
#define PIN_LED_ROJO   12
#define PIN_BUZZER     3
#define PIN_RESET      2

DHT      dht(PIN_DHT, DHT22);
Servo    servoCompuerta;
MPU6050  mpu;


bool accesoAutorizado  = false;
bool horarioHabil      = false;
bool modoMantenimiento = false;
bool sistemaActivo     = true;


volatile bool resetPendiente = false;


const float TEMP_NORMAL_MIN = 15.0;
const float TEMP_NORMAL_MAX = 30.0;
const float TEMP_ALTO_MAX   = 40.0;


const int HUMO_NORMAL_MAX = 300;
const int HUMO_MEDIO_MAX  = 500;


int bufferHumo[5] = {0};
int idxHumo       = 0;


int fallosDHT = 0;


const unsigned long WARMUP_MQ2 = 30000;


float baselineAX = 0, baselineAY = 0, baselineAZ = 0;
bool  mpuListo   = false;


unsigned long ultimoPulso = 0;
bool ledPulsoEncendido    = false;


struct Evento {
  unsigned long tiempo;
  char          msg[40];  
  int           score;
};
Evento logEventos[10];   
int    idxLog = 0;


void calibrarMPU();
int  fn_temperatura();
int  fn_humo();
int  fn_vibracion();
int  fn_movimiento();
void evaluarEstadoGlobal(int score, int scoreTemp, int scoreHumo);
void registrarEvento(const char* msg, int score);
void imprimirDiagnostico(int sT, int sH, int sV, int sM, int total);
void ISR_reset();


void setup() {
  Serial.begin(9600);

  pinMode(PIN_MOVIMIENTO, INPUT);
  pinMode(PIN_LED_VERDE,  OUTPUT);
  pinMode(PIN_LED_AMBAR,  OUTPUT);
  pinMode(PIN_LED_ROJO,   OUTPUT);
  pinMode(PIN_BUZZER,     OUTPUT);
  pinMode(PIN_RESET,      INPUT_PULLUP);

 
  dht.begin();

  
  servoCompuerta.attach(PIN_SERVO);
  servoCompuerta.write(0);

 
  Wire.begin();
  mpu.initialize();
  if (mpu.testConnection()) {
    Serial.println(F("[IMU] MPU6050 OK"));
    calibrarMPU();
  } else {
    Serial.println(F("[IMU] ERROR: MPU6050 no encontrado"));
  }


  attachInterrupt(digitalPinToInterrupt(PIN_RESET), ISR_reset, FALLING);

  digitalWrite(PIN_LED_VERDE, HIGH);
  Serial.println(F("=== VAUTEC INICIADO ==="));
  registrarEvento("Inicio", 0);
}


void loop() {

  
  if (resetPendiente) {
    resetPendiente = false;
    noTone(PIN_BUZZER);
    digitalWrite(PIN_LED_VERDE, HIGH);
    digitalWrite(PIN_LED_AMBAR, LOW);
    digitalWrite(PIN_LED_ROJO,  LOW);
    servoCompuerta.write(0);
    accesoAutorizado  = false;
    modoMantenimiento = false;
    ledPulsoEncendido = false;
    Serial.println(F("[RESET] Sistema reiniciado"));
    registrarEvento("Reset manual", 0);
  }

  if (!sistemaActivo) return;


  int scoreTemp = fn_temperatura();
  int scoreHumo = fn_humo();
  int scoreVibr = fn_vibracion();
  int scoreMov  = fn_movimiento();

  
  int scoreTotal = 0;
  if (scoreTemp >= 0) scoreTotal += scoreTemp;
  if (scoreHumo >= 0) scoreTotal += scoreHumo;
  if (scoreVibr >= 0) scoreTotal += scoreVibr;
  if (scoreMov  >= 0) scoreTotal += scoreMov;

  
  evaluarEstadoGlobal(scoreTotal, scoreTemp, scoreHumo);

 
  static unsigned long ultimoDiag = 0;
  if (millis() - ultimoDiag >= 5000) {
    ultimoDiag = millis();
    imprimirDiagnostico(scoreTemp, scoreHumo, scoreVibr, scoreMov, scoreTotal);
  }

  delay(800);
}


void calibrarMPU() {
  Serial.println(F("[IMU] Calibrando baseline..."));
  int16_t ax, ay, az, gx, gy, gz;
  float sx = 0, sy = 0, sz = 0;

  for (int i = 0; i < 100; i++) {
    mpu.getMotion6(&ax, &ay, &az, &gx, &gy, &gz);
    sx += ax / 16384.0;
    sy += ay / 16384.0;
    sz += az / 16384.0;
    delay(10);
  }

  baselineAX = sx / 100.0;
  baselineAY = sy / 100.0;
  baselineAZ = sz / 100.0;
  mpuListo   = true;

  Serial.println(F("[IMU] Calibracion completa"));
}


int fn_temperatura() {
  float temp = dht.readTemperature();

  if (isnan(temp)) {
    fallosDHT++;
    if (fallosDHT > 3) {
      Serial.println(F("[TEMP] FALLO: DHT22 no responde"));
      registrarEvento("Fallo DHT22", -1);
    }
    return -1;
  }
  fallosDHT = 0;

  if (modoMantenimiento) {
    return (temp <= TEMP_ALTO_MAX + 5) ? 0 : 1;
  }

  if (temp >= TEMP_NORMAL_MIN && temp <= TEMP_NORMAL_MAX) return 0;

  if ((temp > TEMP_NORMAL_MAX && temp <= TEMP_ALTO_MAX) ||
      (temp < TEMP_NORMAL_MIN && temp >= 10.0)) {
    Serial.print(F("[TEMP] Medio: ")); Serial.println(temp);
    return 1;
  }

  Serial.print(F("[TEMP] CRITICO: ")); Serial.println(temp);
  registrarEvento("Temp critica", 2);
  return 2;
}


int fn_humo() {
  if (millis() < WARMUP_MQ2) {
    return -1;  
  }

  int raw = analogRead(PIN_MQ2);
  bufferHumo[idxHumo] = raw;
  idxHumo = (idxHumo + 1) % 5;

  int filtrado = 0;
  for (int i = 0; i < 5; i++) filtrado += bufferHumo[i];
  filtrado /= 5;

  if (modoMantenimiento) {
    return (filtrado < HUMO_MEDIO_MAX + 100) ? 0 : 1;
  }

  if (filtrado < HUMO_NORMAL_MAX) return 0;

  if (filtrado <= HUMO_MEDIO_MAX) {
    Serial.print(F("[HUMO] Medio: ")); Serial.println(filtrado);
    return 1;
  }

  Serial.print(F("[HUMO] CRITICO: ")); Serial.println(filtrado);
  registrarEvento("Humo critico", 2);
  return 2;
}


int fn_vibracion() {
  if (!mpuListo) return -1;

  int16_t ax, ay, az, gx, gy, gz;
  mpu.getMotion6(&ax, &ay, &az, &gx, &gy, &gz);

  float acX = ax / 16384.0;
  float acY = ay / 16384.0;
  float acZ = az / 16384.0;

  float dX = abs(acX - baselineAX);
  float dY = abs(acY - baselineAY);
  float dZ = abs(acZ - baselineAZ);

  float mag = sqrt(dX*dX + dY*dY + dZ*dZ);

  if (modoMantenimiento) {
    return (mag < 0.8) ? 0 : 1;
  }

  if (mag < 0.05) return 0;

  if (mag < 0.25) {
    if (horarioHabil) return 0;
    Serial.println(F("[VIBR] Leve fuera de horario"));
    return 1;
  }

  if (mag < 0.6) {
    Serial.print(F("[VIBR] Medio mag=")); Serial.println(mag);
    return 1;
  }

  Serial.print(F("[VIBR] CRITICO mag=")); Serial.println(mag);
  registrarEvento("Impacto critico", 2);
  return 2;
}


int fn_movimiento() {
  int lectura = digitalRead(PIN_MOVIMIENTO);

  if (lectura == LOW) return 0;

  if (accesoAutorizado) {
    Serial.println(F("[MOV] Autorizado — OK"));
    return 0;
  }

  if (horarioHabil) {
    Serial.println(F("[MOV] Horario habil sin auth"));
    return 1;
  }

  Serial.println(F("[MOV] CRITICO: Intrusion"));
  registrarEvento("Intrusion", 2);
  return 2;
}


void evaluarEstadoGlobal(int score, int scoreTemp, int scoreHumo) {

  
  digitalWrite(PIN_LED_VERDE, LOW);
  digitalWrite(PIN_LED_AMBAR, LOW);
  digitalWrite(PIN_LED_ROJO,  LOW);
  noTone(PIN_BUZZER);


  if (scoreTemp == 2 && scoreHumo == 2) {
    servoCompuerta.write(0);
    digitalWrite(PIN_LED_ROJO, HIGH);
    tone(PIN_BUZZER, 2500, 800);
    Serial.println(F("[GLOBAL] INCENDIO — COMPUERTA ABIERTA"));
    registrarEvento("INCENDIO", score);
    return;
  }


  if (scoreTemp == 2 && scoreHumo != 2) {
    servoCompuerta.write(90);
    digitalWrite(PIN_LED_ROJO, HIGH);
    tone(PIN_BUZZER, 1800, 600);
    Serial.println(F("[GLOBAL] Temp alta sin humo — investigar"));
    return;
  }


  if (score == 0) {
    digitalWrite(PIN_LED_VERDE, HIGH);
    servoCompuerta.write(0);

  } else if (score <= 2) {
    digitalWrite(PIN_LED_AMBAR, HIGH);
    servoCompuerta.write(45);
    tone(PIN_BUZZER, 1000, 300);
    Serial.println(F("[GLOBAL] MEDIO"));

  } else if (score <= 5) {
    digitalWrite(PIN_LED_ROJO, HIGH);
    servoCompuerta.write(90);
    tone(PIN_BUZZER, 1500, 400);
    Serial.println(F("[GLOBAL] ALTO"));
    registrarEvento("Estado ALTO", score);

  } else {
    
    servoCompuerta.write(180);
    if (millis() - ultimoPulso >= 300) {
      ultimoPulso = millis();
      ledPulsoEncendido = !ledPulsoEncendido;
      digitalWrite(PIN_LED_ROJO, ledPulsoEncendido);
      if (ledPulsoEncendido) tone(PIN_BUZZER, 2000, 250);
    }
    Serial.println(F("[GLOBAL] CRITICO"));
    registrarEvento("CRITICO", score);
  }
}


void registrarEvento(const char* msg, int score) {
  logEventos[idxLog].tiempo = millis() / 1000;
  strncpy(logEventos[idxLog].msg, msg, 39);
  logEventos[idxLog].msg[39] = '\0';
  logEventos[idxLog].score   = score;
  idxLog = (idxLog + 1) % 10;
}


void ISR_reset() {
  resetPendiente = true;
}



void imprimirDiagnostico(int sT, int sH, int sV, int sM, int total) {
  Serial.println(F("\n--- VAUTEC DIAGNOSTICO ---"));
  Serial.print(F("T:")); Serial.print(sT);
  Serial.print(F(" H:")); Serial.print(sH);
  Serial.print(F(" V:")); Serial.print(sV);
  Serial.print(F(" M:")); Serial.print(sM);
  Serial.print(F(" | Score:")); Serial.println(total);
  Serial.print(F("Auth:")); Serial.print(accesoAutorizado ? F("SI") : F("NO"));
  Serial.print(F(" Horario:")); Serial.print(horarioHabil ? F("SI") : F("NO"));
  Serial.print(F(" Mant:")); Serial.println(modoMantenimiento ? F("SI") : F("NO"));
  Serial.println(F("Eventos:"));
  for (int i = 0; i < 5; i++) {
    if (logEventos[i].tiempo > 0) {
      Serial.print(F("  ["));
      Serial.print(logEventos[i].tiempo);
      Serial.print(F("s] "));
      Serial.println(logEventos[i].msg);
    }
  }
  Serial.println(F("--------------------------\n"));
}
